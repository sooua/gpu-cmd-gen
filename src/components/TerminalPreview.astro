---
<div class="terminal-container" id="terminalContainer">
  <div class="terminal-chrome">
    <div class="terminal-header">
      <div class="terminal-btn close"></div>
      <div class="terminal-btn minimize"></div>
      <div class="terminal-btn maximize"></div>
      <div class="terminal-title" id="terminalHeaderTitle">ubuntu@terminal: ~</div>
    </div>
    <div id="terminal"></div>
  </div>

  <div class="download-section">
    <button class="btn-secondary" id="downloadBtn2" data-lang-key="downloadTerminal">
      下载终端 HTML
    </button>
    <button class="btn-secondary" id="downloadPngBtn" data-lang-key="downloadPng">
      下载 PNG
    </button>
  </div>
</div>
