---
---
<nav class="top-nav">
  <div class="logo-section">
    <h1>GPU-Cmd-Gen</h1>
    <p class="subtitle" data-lang-key="subtitle">生成逼真的Ubuntu终端界面 - 支持超算集群、GPU服务器等多种预设</p>
  </div>

  <div class="nav-controls">
    <div class="control-buttons">
      <button class="icon-btn" id="themeToggle" title="Toggle theme" aria-label="Toggle theme">
        <svg id="themeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <div class="lang-selector">
        <button class="lang-btn" id="langBtn" aria-haspopup="true" aria-expanded="false">
          <span id="currentLang">🇨🇳 中文</span>
          <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
            <path d="M5 7L1 3h8z"/>
          </svg>
        </button>
        <div class="lang-dropdown" id="langDropdown" role="menu">
          <div class="lang-option active" data-lang="zh" role="menuitem">🇨🇳 中文</div>
          <div class="lang-option" data-lang="en" role="menuitem">🇺🇸 English</div>
        </div>
      </div>
    </div>
  </div>
</nav>
